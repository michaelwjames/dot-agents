GROQ_API_KEY=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

LLM_PROVIDER=groq

GROQ_MODEL=openai/gpt-oss-20b
GROQ_MODEL_2=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_3=
GROQ_WHISPER_MODEL=whisper-large-v3

# Gemini Configuration (required if LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_MODEL_2=gemini-2.5-flash
GEMINI_MODEL_3=null
GEMINI_API_KEY=

TERMINAL_MODE=false

# Reactive mode only (no proactive ticks)
KAIROS_ENABLED=false
 
# Disable compression (saves 1 call per 20 messages)
COMPRESSION_ENABLED=false
 
# Limit tool rounds (prevents infinite loops)
MAX_TOOL_ROUNDS=5

# Jules cache database location
JULES_CACHE_DB=tmp/jules_cache.db

BOSS_WRITABLE_DATA_DIR=tmp